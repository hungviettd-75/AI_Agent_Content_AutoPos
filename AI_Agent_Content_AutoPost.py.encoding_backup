def _knowledge_value(row, key, default=""):
    """Read a value from a pandas Series, sqlite row, or dict."""
    try:
        value = row.get(key, default)
    except AttributeError:
        try:
            value = row[key]
        except Exception:
            value = default
    if value is None:
        return default
    return value


