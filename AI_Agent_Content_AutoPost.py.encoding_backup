def build_content_summary(content, max_length=220):
    clean_content = " ".join(str(content or "").split())
    if len(clean_content) <= max_length:
        return clean_content
    return clean_content[:max_length].rsplit(" ", 1)[0] + "..."


def save_knowledge_post(
    date=None,
    platform="",
    topic="",
    audience="",
    tool_name="",
    knowledge_type="",
    difficulty="",
    content="",
    summary="",
    status="Draft"
):
    """Save an AI knowledge-sharing post to SQLite and return the new row id."""
    if not date:
        date = datetime.now().strftime("%d/%m/%Y %H:%M")
    if not summary:
        summary = build_content_summary(content)

    conn = get_db_connection()
    c = conn.cursor()
    c.execute(
        """INSERT INTO knowledge_posts
           (date, platform, topic, audience, tool_name, knowledge_type, difficulty, content, summary, status)
           VALUES (?,?,?,?,?,?,?,?,?,?)""",
        (date, platform, topic, audience, tool_name, knowledge_type, difficulty, content, summary, status)
    )
    conn.commit()
    new_id = c.lastrowid
    conn.close()
    return new_id

def get_knowledge_posts(status=None, platform=None, limit=None):
    """Return knowledge posts as a pandas DataFrame, newest first."""
    conn = get_db_connection()
    query = "SELECT * FROM knowledge_posts"
    filters = []
    params = []

    if status:
        filters.append("status = ?")
        params.append(status)
    if platform:
        filters.append("platform = ?")
        params.append(platform)
    if filters:
        query += " WHERE " + " AND ".join(filters)
    query += " ORDER BY id DESC"
    if limit:
        query += " LIMIT ?"
        params.append(limit)

    df = pd.read_sql_query(query, conn, params=params)
    conn.close()
    return df


def delete_knowledge_post(post_id):
    """Delete one knowledge post by id. Returns True when a row was deleted."""
    conn = get_db_connection()
    c = conn.cursor()
    c.execute("DELETE FROM knowledge_posts WHERE id = ?", (post_id,))
    deleted = c.rowcount > 0
    conn.commit()
    conn.close()
    return deleted

