# Copy this file to .env locally, or add the same keys in your hosting dashboard.

# App security
SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=24

# Database
# For a quick trial, sqlite is simplest. For production, switch to postgresql.
DB_ENGINE=sqlite
DB_PATH=content_manager.db

# PostgreSQL, only when DB_ENGINE=postgresql
PG_DSN=
PG_HOST=localhost
PG_PORT=5432
PG_NAME=ai_agent_marketing
PG_USER=postgres
PG_PASSWORD=

# AI/API keys
GEMINI_API_KEY=
FB_PAGE_ID=
FB_ACCESS_TOKEN=
ZALO_OA_ID=
ZALO_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_ACCESS_TOKEN=

# Logging
LOG_LEVEL=INFO
LOG_FILE=app_execution.log
